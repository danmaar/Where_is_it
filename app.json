{
  "expo": {
    "name": "Where is it?",
    "slug": "gde-lezhit",
    "scheme": "gde-lezhit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/logo_inventory.png",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_inventory.png",
        "backgroundColor": "#00000000"
      },
      "package": "com.codex.gdelezhit",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Разрешите доступ к фото, чтобы прикреплять изображения к предметам.",
          "cameraPermission": "Разрешите доступ к камере, чтобы фотографировать предметы."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
